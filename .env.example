# Local database. Start it with `docker compose up -d`.
DATABASE_URL="postgresql://storybook:storybook@localhost:5432/storybook?schema=public"

# Doubao / Volcengine Ark story and image generation.
DOUBAO_API_KEY=""
DOUBAO_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_STORY_MODEL="doubao-seed-1-6-flash-250615"
DOUBAO_IMAGE_MODEL="doubao-seedream-5-0-260128"
DOUBAO_STORY_TIMEOUT_MS="90000"
DOUBAO_STORY_MAX_RETRIES="0"
DOUBAO_IMAGE_SIZE="2K"
DOUBAO_IMAGE_TIMEOUT_MS="180000"
DOUBAO_IMAGE_MAX_RETRIES="0"

# Optional Doubao / Volcengine narration generation.
# This key is separate from DOUBAO_API_KEY / Ark.
DOUBAO_TTS_API_KEY=""
DOUBAO_TTS_APP_ID=""
DOUBAO_TTS_ACCESS_KEY=""
DOUBAO_TTS_ENDPOINT="https://openspeech.bytedance.com/api/v3/tts/unidirectional"
DOUBAO_TTS_RESOURCE_ID="seed-tts-2.0"
DOUBAO_TTS_VOICE_TYPE="zh_female_shaoergushi_uranus_bigtts"
DOUBAO_TTS_SAMPLE_RATE="24000"
DOUBAO_TTS_SPEECH_RATE="-8"
DOUBAO_TTS_USER_ID="storybook-ai-local"

# Local generation defaults.
PER_BOOK_IMAGE_CONCURRENCY="1"
KEEP_REFERENCE_IMAGES_AFTER_GENERATION="true"
