  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "init:local": "tsx scripts/init-local.ts",
    "doctor": "tsx scripts/check-local-config.ts",
    "doctor:doubao": "tsx scripts/check-doubao.ts",
    "db:up": "docker compose up -d",
    "db:generate": "prisma generate",
    "db:setup": "prisma generate && prisma migrate deploy",
    "db:studio": "prisma studio",
    "setup:local": "npm run doctor && npm run db:up && npm run db:setup",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.38.0",
    "jsonrepair": "^3.14.0",
    "next": "16.2.6",
    "openai": "^6.37.0",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
